; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Visual Novel Kit"
config/version="1.0.0-beta-3"
config/tags=PackedStringArray("rakugo", "template")
run/main_scene="res://scenes/Bootstrap/bootstrap.tscn"
config/features=PackedStringArray("4.6")
config/icon="res://icon.svg"
addons/rakugo_game_template/loading_scene_path="res://scenes/LoadingScreen/LoadingScreen.tscn"
addons/rakugo_game_template/main_menu_path="res://scenes/MainMenu/MainMenu.tscn"
addons/rakugo_game_template/first_game_scene_path="res://scenes/Game/game.tscn"
addons/icon_finder/preview_size=24
addons/rakugo/game_version=1.0
addons/rakugo/narrator_name="narrator"
addons/rakugo/debug=false
addons/visual_novel_kit/default_markup_setting="res://addons/visualnovelkit/default_markups/def_markdown.tres"
addons/visual_novel_kit/at_predefind/center=Vector2(50, 50)
addons/visual_novel_kit/at_predefind/left=25.0
addons/visual_novel_kit/at_predefind/right=75.0
addons/visual_novel_kit/at_predefind/top=25.0
addons/visual_novel_kit/at_predefind/bottom=75.0
addons/rakugo/save_folder="user://saves"

[autoload]

AppSettings="*uid://c8x01bc0wfdl3"
SceneLoader="*uid://bsvqdo0dqh0ao"
ProjectMusicController="*uid://r5t485lr3p7t"
UISoundManager="*uid://cc37235kj4384"
Transitions="*uid://b0w163uxufsvm"
Rakugo="*uid://n8ftqei0e84h"
AdvancedText="*uid://drvqrd43l3dgv"
HintPopup="*uid://d1qw62h10t5vw"
IconsFonts="*uid://b5tsg0jpnhhhf"
RKSShow="*uid://ctkpjrdmlyr00"
RKSAnim="*res://addons/visualnovelkit/rks_extensions/rks_anim.gd"
RKSAudio="*res://addons/visualnovelkit/rks_extensions/rks_audio.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=false
window/stretch/mode="canvas_items"

[docks]

filesystem/textfile_extensions="txt,md,cfg,ini,log,json,yml,yaml,toml,xml,rk"

[editor]

script/search_in_file_extensions=PackedStringArray("gd", "gdshader", "rk")

[editor_plugins]

enabled=PackedStringArray("res://addons/RakuScript_Color/plugin.cfg", "res://addons/Rakugo/plugin.cfg", "res://addons/advanced-text/plugin.cfg", "res://addons/icons-fonts/plugin.cfg", "res://addons/rakugo-nodes/plugin.cfg", "res://addons/rakugo_game_template/plugin.cfg", "res://addons/rakugo_regex_lab/plugin.cfg", "res://addons/visualnovelkit/plugin.cfg")

[gui]

common/drop_mouse_on_gui_input_disabled=true

